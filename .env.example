TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
NEWS_API_KEY=

# Personalization
RECIPIENT_NAME=Sunil
TZ=Europe/Oslo
NORWAY_NEWS_QUERY=Norway OR Norge

# Bot runtime
REQUEST_TIMEOUT_SECONDS=15
TELEGRAM_MESSAGE_MAX_CHARS=3900
STATE_FILE=.news_bot_state.json
COMMAND_POLL_ENABLED=true
COMMAND_POLL_INTERVAL_MINUTES=2
HEALTH_PING_ENABLED=true
HEALTH_PING_CHAT_ID=

# News quality filters (comma-separated domains)
TRUSTED_NEWS_DOMAINS=reuters.com,bloomberg.com,cnbc.com,finance.yahoo.com,yahoo.com,ft.com,bbc.com,theguardian.com,nrk.no,aftenposten.no,apnews.com
BLOCKED_NEWS_DOMAINS=news.google.com,pinterest.com,tiktok.com

# Trade screener risk controls
TRADE_MIN_SCORE=3
TRADE_MIN_WEEK_MOMENTUM_PCT=1.0
TRADE_MIN_DAY_CHANGE_PCT=0.0
TRADE_MIN_VOLUME_RATIO=1.2
TRADE_MAX_DRAWDOWN_PCT=8.0
TRADE_MAX_ATR_PCT=4.5

# Optional universe overrides
# Format: Label:SYMBOL,Label 2:SYMBOL2
USA_STOCK_UNIVERSE=Apple:AAPL,Microsoft:MSFT,NVIDIA:NVDA
INDIA_STOCK_UNIVERSE=Reliance:RELIANCE.NS,TCS:TCS.NS
NORWAY_STOCK_UNIVERSE=Equinor:EQNR.OL,DNB Bank:DNB.OL
INDIA_MUTUAL_FUNDS=Nippon Nifty BeES:NIFTYBEES.NS,SBI Nifty 50 ETF:SETFNIF50.NS
NORWAY_MUTUAL_FUNDS=iShares MSCI Norway ETF:ENOR,Global X Norway ETF:NORW
