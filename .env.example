TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Personalization
RECIPIENT_NAME=Sunil
TZ=Europe/Oslo

# Bot runtime
REQUEST_TIMEOUT_SECONDS=15
TELEGRAM_MESSAGE_MAX_CHARS=3900
STATE_FILE=.news_bot_state.json
COMMAND_POLL_ENABLED=true
COMMAND_POLL_INTERVAL_MINUTES=2
HEALTH_PING_ENABLED=true
HEALTH_PING_CHAT_ID=

# News quality filters (comma-separated domains)
TRUSTED_NEWS_DOMAINS=reuters.com,bloomberg.com,cnbc.com,finance.yahoo.com,yahoo.com,ft.com,bbc.com,theguardian.com,nrk.no,aftenposten.no,e24.no,apnews.com,marketwatch.com
BLOCKED_NEWS_DOMAINS=news.google.com,pinterest.com,tiktok.com

# Public feed configuration (comma-separated URLs / screener IDs)
GLOBAL_NEWS_FEEDS=https://feeds.bbci.co.uk/news/world/rss.xml,https://www.cnbc.com/id/100727362/device/rss/rss.html,https://feeds.apnews.com/apf-topnews
BUSINESS_NEWS_FEEDS=https://www.cnbc.com/id/10001147/device/rss/rss.html,https://finance.yahoo.com/news/rssindex,https://feeds.marketwatch.com/marketwatch/topstories/
NORWAY_NEWS_FEEDS=https://www.nrk.no/toppsaker.rss,https://e24.no/rss,https://www.aftenposten.no/rss
STOCK_SCREENERS=day_gainers,most_actives
FUND_SCREENERS=conservative_foreign_funds,solid_large_growth_funds,high_yield_bond
SCREENER_QUOTE_LIMIT=50
SEND_STARTUP_BRIEFING=false

# Trade screener risk controls
TRADE_MIN_SCORE=3
TRADE_MIN_WEEK_MOMENTUM_PCT=1.0
TRADE_MIN_DAY_CHANGE_PCT=0.0
TRADE_MIN_VOLUME_RATIO=1.2
TRADE_MAX_DRAWDOWN_PCT=8.0
TRADE_MAX_ATR_PCT=4.5

# Optional universe overrides
# Format: Label:SYMBOL,Label 2:SYMBOL2
USA_STOCK_UNIVERSE=
INDIA_STOCK_UNIVERSE=
NORWAY_STOCK_UNIVERSE=
INDIA_MUTUAL_FUNDS=
NORWAY_MUTUAL_FUNDS=
